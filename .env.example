# --- AI provider (optional) ---
# Huntly's agents work fully offline with realistic mock output. Set these
# to route agent reasoning through a real LLM instead (OpenAI-compatible
# chat completions API, e.g. GPT-5.5).
AI_PROVIDER_API_KEY=
AI_PROVIDER_BASE_URL=https://api.openai.com/v1
AI_PROVIDER_MODEL=gpt-5.5

# --- Supabase (optional) ---
# Only used by the waitlist form. Without these set, the waitlist API route
# falls back to an in-memory store so the demo still works end-to-end.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
